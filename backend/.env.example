# .env.example — copy to .env and fill in values
# Never commit .env to version control

# Input CSV path
INPUT_CSV=ecommerce_orders.csv

# Output directories
OUTPUT_DIR=output
REJECTED_DIR=output/rejected
REPORT_PATH=output/quality_report.json

# Spark settings
SPARK_MASTER=local[*]
LOG_LEVEL=WARN

# Java home (if not already on PATH)
# JAVA_HOME=/path/to/jdk
